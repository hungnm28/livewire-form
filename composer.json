{
    "name": "hungnm28/livewire-form",
    "description": "Reusable Blade UI components for Laravel and Livewire applications.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "livewire",
        "blade",
        "tailwind",
        "ui",
        "form"
    ],
    "autoload": {
        "psr-4": {
            "Hungnm28\\LivewireForm\\": "src/"
        },
        "exclude-from-classmap": [
            "/tests/"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Hungnm28\\LivewireForm\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "hungnm28",
            "email": "nguyenmanhhung28@gmail.com"
        }
    ],
    "extra": {
        "laravel": {
            "providers": [
                "\\Hungnm28\\LivewireForm\\LivewireFormServiceProvider"
            ]
        }
    },
    "require": {
        "php": "^8.1|^8.2|^8.3|^8.4|^8.5",
        "illuminate/support": "^10.0|^11.0|^12.0|^13",
        "livewire/livewire": "^3.0|^4.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0|^12.0|^13.0",
        "phpunit/phpunit": "^10.0|^11.0|^12.0|^13.0"
    },
    "suggest": {
        "alpinejs": "Required for modal, aside, theme settings, and interactive components when Livewire does not provide Alpine.",
        "tailwindcss": "Required to compile the utility classes used by the Blade components.",
        "@tabler/icons-webfont": "Required when you do not use the CDN shipped by the package layout."
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test:unit": "vendor/bin/phpunit"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
